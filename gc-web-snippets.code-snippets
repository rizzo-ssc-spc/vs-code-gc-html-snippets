{
  "GCWeb - Skip link": {
    "prefix": "gcweb-skip-link",
    "body": [
      "<ul id=\"wb-tphp\">",
      "\t<li class=\"wb-slc\"><a class=\"wb-sl\" href=\"#wb-cont\">${1:Skip to main content}</a></li>",
      "\t<li class=\"wb-slc\"><a class=\"wb-sl\" href=\"#wb-info\">${2:Skip to About this site}</a></li>",
      "</ul>"
    ],
    "description": "Accessible skip links for GCWeb pages",
    "scope": "html,javascript,javascriptreact,typescript,typescriptreact,vue,njk,liquid"
  },
  "GCWeb - Breadcrumb": {
    "prefix": "gcweb-breadcrumb",
    "body": [
      "<nav aria-label=\"Breadcrumb\" class=\"breadcrumb\">",
      "\t<ol class=\"breadcrumb\">",
      "\t\t<li><a href=\"${1:/}\">Home</a></li>",
      "\t\t<li><a href=\"${2:/section}\">${3:Section}</a></li>",
      "\t\t<li class=\"active\" aria-current=\"page\">${4:Current page}</li>",
      "\t</ol>",
      "</nav>"
    ],
    "description": "Accessible breadcrumb trail for Canada.ca pages",
    "scope": "html,javascript,javascriptreact,typescript,typescriptreact,vue,njk,liquid"
  },
  "GCWeb - Page title": {
    "prefix": "gcweb-page-title",
    "body": [
      "<hgroup id=\"wb-cont\">",
      "\t<p>${1:Subtitle}</p>",
      "\t<h1>${2:Page title}</h1>",
      "</hgroup>"
    ],
    "description": "Canada.ca stacked page title pattern",
    "scope": "html,javascript,javascriptreact,typescript,typescriptreact,vue,njk,liquid"
  },
  "GCWeb - Main container": {
    "prefix": "gcweb-container",
    "body": [
      "<main class=\"container\" property=\"mainContentOfPage\">",
      "\t${1:Page content}",
      "</main>"
