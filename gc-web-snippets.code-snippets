    "description": "GCWeb main content container",
    "scope": "html,javascript,javascriptreact,typescript,typescriptreact,vue,njk,liquid"
  },
  "GCWeb - Basic table": {
    "prefix": "gcweb-table",
    "body": [
      "<table class=\"table table-bordered\" aria-describedby=\"${1:table-caption}\">",
      "\t<caption id=\"${1:table-caption}\">${2:Summary of data}</caption>",
      "\t<thead>",
      "\t\t<tr>",
      "\t\t\t<th scope=\"col\">${3:Column 1}</th>",
      "\t\t\t<th scope=\"col\">${4:Column 2}</th>",
      "\t\t</tr>",
      "\t</thead>",
      "\t<tbody>",
      "\t\t<tr>",
      "\t\t\t<td>${5:Value 1}</td>",
      "\t\t\t<td>${6:Value 2}</td>",
      "\t\t</tr>",
      "\t</tbody>",
      "</table>"
